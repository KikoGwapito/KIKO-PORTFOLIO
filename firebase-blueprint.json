{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global application settings and content",
      "type": "object",
      "properties": {
        "hero": { "type": "object" },
        "trust": { "type": "object" },
        "featuredWork": { "type": "object" },
        "pageTitle": { "type": "object" },
        "about": { "type": "object" },
        "process": { "type": "object" },
        "contact": { "type": "object" },
        "theme": { "type": "object" },
        "cloudinary": { "type": "object" },
        "projectOrder": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "images": { "type": "array", "items": { "type": "object" } },
        "galleryGrid": { "type": "string" },
        "role": { "type": "string" },
        "timeline": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title"]
    },
    "Review": {
      "title": "Review",
      "description": "A client review",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "clientRole": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["clientName", "content", "rating"]
    }
  },
  "firestore": {
    "/settings/main": {
      "schema": "Settings",
      "description": "Main application configuration"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Individual portfolio projects"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Client reviews"
    }
  }
}
